# See src/lib/env.ts for the full list of supported environment variables.

# Encryption key (aes-256-cbc) used by the Saleor app SDK. 16 or 32 bytes hex.
# Generate with: openssl rand -hex 32
SECRET_KEY=

# Regex pattern controlling Saleor domains the app can be installed on.
ALLOWED_DOMAIN_PATTERN=/*/

# APL=file   # "file" for local dev, "dynamodb" for production
# APP_LOG_LEVEL=info

# App URLs. When developed locally with Saleor in Docker, use:
# APP_IFRAME_BASE_URL=http://localhost:3000
# APP_API_BASE_URL=http://host.docker.internal:3000
# Leave empty when using tunnels.
# APP_IFRAME_BASE_URL=
# APP_API_BASE_URL=

# Scheduler — leave defaults unless debugging.
# SCHEDULER_DISABLED=false  # set to true to suppress in-process ticks
# SCHEDULER_INTERVAL_SECONDS=60

# DynamoDB (required when APL=dynamodb). The Saleor app SDK DynamoAPL writes
# items keyed by attributes named `PK` (HASH) and `SK` (RANGE), both String;
# tables that use different key names will fail registration.
AWS_REGION=localhost
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=http://localhost:8000
DYNAMODB_MAIN_TABLE_NAME=abandoned-cart-app-main
