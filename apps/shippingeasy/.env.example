# See src/lib/env.ts for exhaustive list of supported and required env variables

# The key used for encryption aes-256-cbc algorithm, which requires 16 or 32 bytes key in hex encoding.
# Generate with: openssl rand -hex 32
SECRET_KEY=

# Regex pattern controlling Saleor domains the app can be installed on.
ALLOWED_DOMAIN_PATTERN=/*/

# APL=file   # "file" for local dev, "dynamodb" for production
# APP_LOG_LEVEL=info

# App URLs. When developed locally with Saleor in Docker, use:
# APP_IFRAME_BASE_URL=http://localhost:3000
# APP_API_BASE_URL=http://host.docker.internal:3000
# Leave empty when using tunnels.
# APP_IFRAME_BASE_URL=
# APP_API_BASE_URL=

# ShippingEasy REST API base URL (override for regional endpoints or mocks).
# SHIPPINGEASY_API_BASE_URL=https://app.shippingeasy.com/api

# DynamoDB (required when APL=dynamodb)
# Table key schema must use attribute names PK (HASH) and SK (RANGE), both String.
# The Saleor app SDK DynamoAPL always writes those names; tables like PK-SHIPPING-EASY / SK-* will break registration.
AWS_REGION=localhost
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=http://localhost:8000
DYNAMODB_MAIN_TABLE_NAME=shippingeasy-main-table
